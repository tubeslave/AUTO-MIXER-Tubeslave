# Copy this file to tools/paperclip_watchdog/.env and fill local values.
# Do not commit real tokens.

PAPERCLIP_API_URL=http://127.0.0.1:3100
PAPERCLIP_COMPANY_ID=
PAPERCLIP_TOKEN=

AUTOMIXER_WATCHDOG_INTERVAL_SECONDS=180
AUTOMIXER_WATCHDOG_DRY_RUN=true
AUTOMIXER_WATCHDOG_MAX_TASKS_PER_DAY=8
AUTOMIXER_WATCHDOG_COOLDOWN_SECONDS=1800
AUTOMIXER_WATCHDOG_LOG=logs/automixer_paperclip_watchdog.log
AUTOMIXER_WATCHDOG_STATE=.paperclip/watchdog_state.json
AUTOMIXER_WATCHDOG_PAUSE=.paperclip/watchdog_paused
AUTOMIXER_WATCHDOG_REPORTS_DIR=.paperclip/reports

# Safe dispatch policy. Defaults are intentionally non-dispatching.
AUTOMIXER_WATCHDOG_DISPATCH_ENABLED=false
AUTOMIXER_WATCHDOG_DISPATCH_DRY_RUN=true
AUTOMIXER_WATCHDOG_DISPATCH_ALLOWLIST_AGENT_IDS=
AUTOMIXER_WATCHDOG_DISPATCH_ISSUE_ID=
AUTOMIXER_WATCHDOG_DISPATCH_AGENT_ID=
AUTOMIXER_WATCHDOG_DISPATCH_TASK_KEY=
AUTOMIXER_WATCHDOG_DISPATCH_REASON=manual watchdog dispatch safety check
AUTOMIXER_WATCHDOG_DISPATCH_IDEMPOTENCY_KEY=
AUTOMIXER_WATCHDOG_DISPATCH_DENY_IF_RUNNING_AGENTS_GT=0
AUTOMIXER_WATCHDOG_DISPATCH_DENY_IF_IN_PROGRESS_TASKS_GT=0
AUTOMIXER_WATCHDOG_DISPATCH_REQUIRE_ISSUE_STATUS=todo
AUTOMIXER_WATCHDOG_DISPATCH_REQUIRE_NO_ACTIVE_RUNS=true
AUTOMIXER_WATCHDOG_DISPATCH_REQUIRE_IDEMPOTENCY_KEY=true
AUTOMIXER_WATCHDOG_DISPATCH_METHOD=patch_issue_assignment
AUTOMIXER_WATCHDOG_DISPATCH_FORBID_DIRECT_WAKEUP_WITHOUT_ASSIGNMENT=true
AUTOMIXER_WATCHDOG_DISPATCH_FORBID_LIVE_OSC=true
AUTOMIXER_WATCHDOG_DISPATCH_FORBID_WING_RUNTIME_WRITE=true

# MOCK mode never calls Paperclip and is useful while endpoints/credentials
# are being confirmed.
AUTOMIXER_WATCHDOG_MOCK=false
# AUTOMIXER_WATCHDOG_MOCK_STATUS_JSON={"api_ok":true,"running_agents":0,"in_progress_tasks":0,"error_agents":0}
