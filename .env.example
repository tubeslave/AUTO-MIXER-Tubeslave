# Copy to `.env` in the repo root (never commit `.env`).
# OpenAI: create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional aliases (see backend/config_manager.py)
# AUTOMIXER_OPENAI_API_KEY=

# Kimi CLI (Moonshot) — binary path if not on PATH
# KIMI_CLI_PATH=/Users/you/.local/bin/kimi
# AUTOMIXER_KIMI_WORK_DIR=
# AUTOMIXER_KIMI_TIMEOUT=120
